---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SiteHeader } from "../components/landing/SiteHeader";
import { SiteFooter } from "../components/landing/SiteFooter";
import toolsData from "@/data/tools.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

type Tool = {
  name: string;
  title: string;
  description: string;
  capabilities: string[];
  hasCode: boolean;
  maturity: string | null;
  state: string;
  docUrl: string;
};

const data = toolsData as {
  capabilities: Record<string, string>;
  tools: Tool[];
  toolsTotal: number;
  implementedTotal: number;
  skills: { total: number; allApache: boolean; license: string };
};

// Stable display order for the capability buckets (matches the taxonomy doc).
const CAP_ORDER = [
  "triage",
  "review",
  "fix",
  "intake",
  "reconciliation",
  "resolve",
  "reassess",
  "stats",
  "setup",
];
const caps = CAP_ORDER.filter((c) => c in data.capabilities).map((c) => ({
  key: c,
  def: data.capabilities[c],
  count: data.tools.filter((t) => t.capabilities.includes(c)).length,
}));

const tools = [...data.tools].sort((a, b) => a.name.localeCompare(b.name));

const VENDOR_NEUTRALITY = `${base}/docs/vendor-neutrality`;
const TAXONOMY = `${base}/docs/labels-and-capabilities`;
const PREREQS = `${base}/docs/prerequisites`;

// Badge palettes by implementation state / maturity.
const stateBadge = (t: Tool) =>
  t.hasCode
    ? { label: "Implemented", cls: "bg-success-50 text-success-700 border-success-200" }
    : { label: "Adapter contract", cls: "bg-brand-50 text-brand-700 border-brand-200" };
const maturityBadge = (m: string | null) => {
  if (!m) return null;
  const map: Record<string, string> = {
    stable: "bg-success-50 text-success-700 border-success-200",
    experimental: "bg-warning-50 text-warning-700 border-warning-200",
    proposed: "bg-neutral-100 text-neutral-700 border-neutral-200",
    off: "bg-neutral-100 text-neutral-500 border-neutral-200",
  };
  return { label: m, cls: map[m] ?? map.proposed };
};
---

<BaseLayout
  title="Tools & Capabilities — Apache Magpie"
  description="Every Apache Magpie tool, the capability it provides, and its implementation state — derived directly from the apache/magpie framework."
  editUrl="https://github.com/apache/magpie-site/edit/main/src/pages/tools.astro"
>
  <SiteHeader />

  <main class="flex w-full flex-col items-center bg-default-background px-8 py-16 mobile:px-4 mobile:py-10">
    <div class="flex w-full max-w-[1100px] flex-col gap-12">
      <!-- Header -->
      <header class="flex flex-col gap-4">
        <a href={`${base}/`} class="text-body font-body text-brand-600 hover:text-brand-700">← Back to home</a>
        <div class="flex items-center gap-2 self-start rounded-full border border-solid border-brand-200 bg-brand-50 px-4 py-1.5">
          <span class="text-caption font-caption text-brand-600">Tools &amp; Capabilities</span>
        </div>
        <h1 class="font-['Inter'] text-[38px] font-[700] leading-[44px] text-default-font -tracking-[0.035em] mobile:text-[28px]">
          Every tool, capability, and where it stands today
        </h1>
        <p class="text-body font-body text-subtext-color max-w-[760px]">
          Magpie's workflows (<strong>skills</strong>) never talk to a vendor directly — they declare a
          <strong>capability</strong>, and a <strong>tool</strong> fulfils it. This page lists every tool in the
          framework, the capabilities it provides, and its implementation state. It is generated directly from
          <a class="text-brand-600 hover:text-brand-700 underline" href="https://github.com/apache/magpie/tree/main/tools" target="_blank" rel="noreferrer">apache/magpie/tools</a>,
          so it never drifts from the code.
        </p>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-caption font-caption text-subtext-color">
          <span><strong class="text-default-font">{data.toolsTotal}</strong> tools</span>
          <span><strong class="text-default-font">{data.implementedTotal}</strong> with a landed code implementation</span>
          <span><strong class="text-default-font">{caps.length}</strong> capabilities</span>
          <span><strong class="text-default-font">{data.skills.total}</strong> skills, all {data.skills.license}</span>
        </div>
      </header>

      <!-- Vendor-neutrality callout -->
      <section class="flex flex-col gap-3 rounded-2xl border border-solid border-brand-200 bg-brand-50 px-6 py-6">
        <h2 class="text-heading-3 font-heading-3 text-default-font">Why this matters: vendor neutrality</h2>
        <p class="text-body font-body text-subtext-color max-w-[820px]">
          Because every vendor binding lives in a tool behind a capability contract, swapping a backend — a different
          forge, tracker, mailing list, VCS, or LLM — is a config change, never a rewrite of the workflows. The full
          per-axis status (LLM backend, agentic runtime, forge/tracker, communication channels, source control,
          governance) lives in the framework's own write-up.
        </p>
        <div class="flex flex-wrap gap-3 pt-1">
          <a class="inline-flex items-center gap-1 rounded-md border border-solid border-brand-300 bg-default-background px-3 py-1.5 text-caption font-caption text-brand-700 hover:bg-brand-100" href={VENDOR_NEUTRALITY}>
            How Magpie achieves vendor neutrality →
          </a>
          <a class="inline-flex items-center gap-1 rounded-md border border-solid border-brand-300 bg-default-background px-3 py-1.5 text-caption font-caption text-brand-700 hover:bg-brand-100" href={TAXONOMY}>
            Skill / tool / capability taxonomy →
          </a>
          <a class="inline-flex items-center gap-1 rounded-md border border-solid border-brand-300 bg-default-background px-3 py-1.5 text-caption font-caption text-brand-700 hover:bg-brand-100" href={PREREQS}>
            Prerequisites →
          </a>
        </div>
      </section>

      <!-- Capability taxonomy -->
      <section class="flex flex-col gap-5">
        <div class="flex flex-col gap-1">
          <h2 class="text-heading-2 font-heading-2 text-default-font">The 9 capabilities</h2>
          <p class="text-body font-body text-subtext-color max-w-[760px]">
            A capability is the stable verb a workflow depends on, independent of which vendor fulfils it. Every tool
            declares the capabilities it provides; every skill declares the ones it needs.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4 mobile:grid-cols-1">
          {caps.map((c) => (
            <div class="flex flex-col gap-2 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm">
              <div class="flex items-center justify-between gap-2">
                <span class="font-mono text-body-bold font-body-bold text-brand-700">capability:{c.key}</span>
                <span class="rounded-full bg-neutral-100 px-2 py-0.5 text-caption font-caption text-subtext-color">{c.count}</span>
              </div>
              <span class="text-caption font-caption text-subtext-color">{c.def}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Implementation-state legend -->
      <section class="flex flex-wrap items-center gap-x-6 gap-y-2 rounded-2xl border border-solid border-neutral-200 bg-neutral-50 px-6 py-4">
        <span class="text-caption-bold font-caption-bold text-default-font">Reading the badges:</span>
        <span class="inline-flex items-center gap-2 text-caption font-caption text-subtext-color">
          <span class="rounded-full border border-solid border-success-200 bg-success-50 px-2 py-0.5 text-success-700">Implemented</span>
          landed code (package + tests)
        </span>
        <span class="inline-flex items-center gap-2 text-caption font-caption text-subtext-color">
          <span class="rounded-full border border-solid border-brand-200 bg-brand-50 px-2 py-0.5 text-brand-700">Adapter contract</span>
          a documented contract with pluggable backends
        </span>
        <span class="inline-flex items-center gap-2 text-caption font-caption text-subtext-color">
          <span class="rounded-full border border-solid border-success-200 bg-success-50 px-2 py-0.5 text-success-700">stable</span>
          /
          <span class="rounded-full border border-solid border-warning-200 bg-warning-50 px-2 py-0.5 text-warning-700">experimental</span>
          /
          <span class="rounded-full border border-solid border-neutral-200 bg-neutral-100 px-2 py-0.5 text-neutral-700">proposed</span>
          spec maturity
        </span>
      </section>

      <!-- Tools grid + capability filter -->
      <section class="flex flex-col gap-5">
        <div class="flex flex-col gap-1">
          <h2 class="text-heading-2 font-heading-2 text-default-font">Browse the {tools.length} tools</h2>
          <p class="text-body font-body text-subtext-color max-w-[760px]">
            Filter by the capability a tool provides. Pick more than one to widen the view —
            a tool is shown if it provides <strong>any</strong> selected capability.
          </p>
        </div>

        <!-- filter chips -->
        <div id="cap-filters" class="flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-cap="__all"
            aria-pressed="true"
            class="cap-chip inline-flex items-center gap-1.5 rounded-full border border-solid px-3 py-1.5 text-caption font-caption transition-colors"
          >
            All
            <span class="rounded-full bg-neutral-100 px-1.5 text-caption font-caption text-subtext-color">{tools.length}</span>
          </button>
          {caps.map((c) => (
            <button
              type="button"
              data-cap={c.key}
              aria-pressed="false"
              title={c.def}
              class="cap-chip inline-flex items-center gap-1.5 rounded-full border border-solid px-3 py-1.5 font-mono text-caption font-caption transition-colors"
            >
              capability:{c.key}
              <span class="rounded-full bg-neutral-100 px-1.5 text-caption font-caption text-subtext-color">{c.count}</span>
            </button>
          ))}
          <button
            type="button"
            id="cap-clear"
            hidden
            class="inline-flex items-center gap-1 rounded-full px-3 py-1.5 text-caption font-caption text-subtext-color underline hover:text-brand-700"
          >
            Clear filter ✕
          </button>
        </div>

        <!-- explanation / status -->
        <div id="cap-status" class="flex flex-col gap-1 rounded-2xl border border-solid border-neutral-200 bg-neutral-50 px-4 py-3">
          <span id="cap-status-text" class="text-caption-bold font-caption-bold text-default-font">
            Showing all {tools.length} tools.
          </span>
          <div id="cap-status-defs" class="flex flex-col gap-0.5"></div>
        </div>

        <div id="tools-grid" class="grid grid-cols-2 gap-4 mobile:grid-cols-1">
          {tools.map((t) => {
            const sb = stateBadge(t);
            const mb = maturityBadge(t.maturity);
            return (
              <a
                href={t.docUrl}
                target="_blank"
                rel="noreferrer"
                data-caps={t.capabilities.join(" ")}
                class="tool-card group flex h-full flex-col gap-3 rounded-2xl border border-solid border-neutral-200 bg-default-background px-5 py-5 shadow-sm hover:border-brand-200 hover:shadow-md transition-all"
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="flex flex-col gap-0.5">
                    <span class="text-body-bold font-body-bold text-default-font group-hover:text-brand-700">{t.title}</span>
                    <span class="font-mono text-caption font-caption text-subtext-color">tools/{t.name}</span>
                  </div>
                  <div class="flex flex-none flex-wrap justify-end gap-1.5">
                    <span class={`rounded-full border border-solid px-2 py-0.5 text-caption font-caption ${sb.cls}`}>{sb.label}</span>
                    {mb && <span class={`rounded-full border border-solid px-2 py-0.5 text-caption font-caption ${mb.cls}`}>{mb.label}</span>}
                  </div>
                </div>
                <p class="text-caption font-caption text-subtext-color">{t.description}</p>
                <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
                  {t.capabilities.map((c) => (
                    <span class="rounded-md bg-neutral-100 px-2 py-0.5 font-mono text-caption font-caption text-neutral-700">{c}</span>
                  ))}
                </div>
              </a>
            );
          })}
        </div>

        <p id="tools-empty" hidden class="rounded-2xl border border-dashed border-neutral-300 px-4 py-6 text-center text-body font-body text-subtext-color">
          No tools match the selected capabilities.
        </p>
      </section>
    </div>
  </main>

  <SiteFooter />

  <script is:inline define:vars={{ capDefs: data.capabilities, total: tools.length }}>
    const filters = document.getElementById("cap-filters");
    if (filters) {
      const chips = [...filters.querySelectorAll("button[data-cap]")];
      const allChip = filters.querySelector('button[data-cap="__all"]');
      const clearBtn = document.getElementById("cap-clear");
      const cards = [...document.querySelectorAll("#tools-grid .tool-card")];
      const statusText = document.getElementById("cap-status-text");
      const statusDefs = document.getElementById("cap-status-defs");
      const empty = document.getElementById("tools-empty");

      // class sets for active / inactive chips (Tailwind tokens used elsewhere)
      const ACTIVE = ["border-brand-300", "bg-brand-50", "text-brand-700"];
      const INACTIVE = ["border-neutral-200", "bg-default-background", "text-default-font"];
      const active = new Set();

      function styleChip(chip, on) {
        chip.classList.remove(...ACTIVE, ...INACTIVE);
        chip.classList.add(...(on ? ACTIVE : INACTIVE));
        chip.setAttribute("aria-pressed", on ? "true" : "false");
      }

      function apply() {
        const sel = [...active];
        // cards
        let shown = 0;
        for (const card of cards) {
          const caps = (card.dataset.caps || "").split(" ").filter(Boolean);
          const match = sel.length === 0 || sel.some((c) => caps.includes(c));
          card.hidden = !match;
          if (match) shown++;
        }
        // chips
        styleChip(allChip, sel.length === 0);
        for (const chip of chips) {
          if (chip === allChip) continue;
          styleChip(chip, active.has(chip.dataset.cap));
        }
        clearBtn.hidden = sel.length === 0;
        empty.hidden = shown !== 0;
        // status text + definitions
        if (sel.length === 0) {
          statusText.textContent = `Showing all ${total} tools.`;
          statusDefs.innerHTML = "";
        } else {
          const names = sel.map((c) => "capability:" + c).join(", ");
          statusText.textContent =
            `Showing ${shown} of ${total} tools that provide ${sel.length === 1 ? "" : "any of "}${names}.`;
          statusDefs.innerHTML = sel
            .map(
              (c) =>
                `<span class="text-caption font-caption text-subtext-color"><span class="font-mono text-default-font">capability:${c}</span> — ${capDefs[c] || ""}</span>`,
            )
            .join("");
        }
      }

      for (const chip of chips) {
        chip.addEventListener("click", () => {
          const cap = chip.dataset.cap;
          if (cap === "__all") active.clear();
          else if (active.has(cap)) active.delete(cap);
          else active.add(cap);
          apply();
        });
      }
      clearBtn.addEventListener("click", () => {
        active.clear();
        apply();
      });
      apply();
    }
  </script>
</BaseLayout>
